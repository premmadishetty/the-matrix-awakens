{
  "name": "the-matrix-awakens-worker",
  "version": "1.0.0",
  "description": "The Matrix Awakens — Neural Proxy on Cloudflare Workers Edge",
  "main": "src/worker.js",
  "type": "module",
  "scripts": {
    "dev":    "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init:local":  "wrangler d1 execute matrix-karma-db --local --file=schema.sql",
